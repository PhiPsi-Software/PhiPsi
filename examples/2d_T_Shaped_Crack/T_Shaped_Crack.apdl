!             ____  _       _   ____  _____   _        
!            |  _ \| |     |_| |  _ \|  ___| |_|       
!            | |_) | |___   _  | |_) | |___   _        
!            |  _ /|  _  | | | |  _ /|___  | | |       
!            | |   | | | | | | | |    ___| | | |       
!            |_|   |_| |_| |_| |_|   |_____| |_|       
!     .................................................
!     PhiPsi:     a general-purpose computational      
!                 mechanics program written in Fortran.
!     Website:    http://phipsi.top                    
!     Author:     Shi Fang from Huaiyin Institute of   
!                 Technology, HuaiAn, JiangSu, China   
!     Contact me: shifang@ustc.edu.cn      
            
finish
/clear
/FILNAME,PhiPsi_T_Shaped_Crack
/PREP7
/DSCALE,ALL,1.0
/eshape,1

!---------
!Control parameters
!---------
W         = 20.0e-3
H         = 21.0e-3
size_mesh = 0.55e-3
Force_y   = 10.e6

!...............
!Elements and materials
!...............
et,1,42
KEYOPT,1,3,1    
KEYOPT,1,6,0
keyopt,1,10,0
mp,ex,1,20e9
mp,nuxy,1,0.2

!...........
!Modeling
!...........
BLC4,0,0,w,h
allsel
lesize,all,size_mesh
MSHAPE,0,2D 
MSHKEY,0
AMESH,all

!...............
! DOF constraints
!...............
allsel
LSEL,S, , ,       2
NSLL,R,1
D,all,all

!................................................
! Load, must be applied to nodes, otherwise node load information cannot be exported
!................................................
allsel
LSEL,S,LOC,Y,H
NSLl,R,1
*get,all_num,NODE,,COUNT,,
c_num = 0
*do,i,1,all_num
	*get,c_num,NODE,c_num,NXTH,
	*get,c_x,NODE,c_num,LOC,X,
	*if,c_x,EQ,0,or,c_x,EQ,W,then                       !Halve at both ends
	    F,c_num,FY,Force_y*size_mesh*0.5
	*else                                                   
	    F,c_num,FY,Force_y*size_mesh
	*endif
*enddo
allsel
LSEL,S,LOC,Y,0
NSLl,R,1
*get,all_num,NODE,,COUNT,,
c_num = 0
*do,i,1,all_num
	*get,c_num,NODE,c_num,NXTH,
	*get,c_x,NODE,c_num,LOC,X,
	*if,c_x,EQ,0,or,c_x,EQ,W,then                       !Halve at both ends
	    F,c_num,FY,-Force_y*size_mesh*0.5
	*else                                                   
	    F,c_num,FY,-Force_y*size_mesh
	*endif
*enddo
allsel
/replot

!................................
! Export input data required for PhiPsi operation
!...............................
Ansys2PhiPsi_2D.mac,'T_Shaped_Crack'
!
! /solu
! time,1
! solve
! /POST1  
! PLNSOL, S,EQV, 0,1.0
